# Copy to .env and fill in your values. The .env file is gitignored.
# Only configure the sections for widgets you actually use.

# ── Server ────────────────────────────────────────────────────────────────────

# Linux user that owns the config files written by the backend.
# Run: echo "UID=$(id -u) GID=$(id -g)" to get your values.
UID=1000
GID=1000

# LAN address of this Docker host, as seen from the Chromecasts.
# ⚠ Not http://localhost — the TV resolves localhost as itself.
SERVER_URL=http://192.168.1.10

# ── General ───────────────────────────────────────────────────────────────────

# IANA timezone for date/time display and calendar events. Default: UTC.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Europe/Amsterdam

# ── Calendar widget ───────────────────────────────────────────────────────────
# Reads Google Calendar via a service account (no OAuth pop-ups).
#
# Setup:
#   1. Create a service account at https://console.cloud.google.com
#      → APIs & Services → Credentials → Create Credentials → Service Account
#   2. Enable the Google Calendar API on the same project.
#   3. Download the JSON key → save as config/google-sa.json (gitignored).
#   4. Share each calendar with the service account email
#      (Settings → calendar → Share → add the ...@iam.gserviceaccount.com address).
#   5. Copy the Calendar ID from Settings → calendar → Integrate calendar.

# Path to the service account JSON key (default shown; rarely needs changing).
GOOGLE_SA_KEY_FILE=/config/google-sa.json

# Primary calendar ID — your Gmail address or a group calendar ID.
GOOGLE_CALENDAR_ID=yourname@gmail.com

# ── Traffic widget ────────────────────────────────────────────────────────────
# Travel time uses TomTom (free key, no credit card).
# Traffic jam list uses the public ANWB API — no key needed.
# Home/work address and route roads are configured in the admin panel.
#
# Get a TomTom key at: https://developer.tomtom.com

TOMTOM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Bus widget ────────────────────────────────────────────────────────────────
# Real-time departures via vertrektijd.info (Netherlands only, free account).
# Stop city and name are configured in the admin panel.
# Register at: https://vertrektijd.info/starten.html

VERTREKTIJD_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Polestar widget ───────────────────────────────────────────────────────────
# Shows battery, range, charging status, and odometer for a Polestar EV.
# Same credentials as the Polestar app / my.polestar.com.

POLESTAR_USERNAME=driver@example.com
POLESTAR_PASSWORD=your-polestar-password

# ── Network widget ─────────────────────────────────────────────────────────────
# Router password for the Zyxel VMG8825 DAL API.
# Router URL and username are set in the admin panel (General → Network widget).
# Without this the widget still shows connectivity, DNS, and speed.

ROUTER_PASSWORD=your-router-password
