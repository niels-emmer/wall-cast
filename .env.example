# Copy this file to .env and fill in your values.
# The .env file is gitignored and never committed.
#
# Most settings are optional — only configure the sections for widgets you use.

# ---------------------------------------------------------------------------
# TIMEZONE
# ---------------------------------------------------------------------------
# IANA timezone name used for the calendar widget (date/time display).
# See https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Default: UTC
TIMEZONE=Europe/Amsterdam


# ---------------------------------------------------------------------------
# GARBAGE COLLECTION — mijnafvalwijzer.nl (Netherlands only)
# ---------------------------------------------------------------------------
# Required only if you use the `garbage` widget type.
# Find your postcode and house number on https://www.mijnafvalwijzer.nl
GARBAGE_POSTCODE=1234AB
GARBAGE_HUISNUMMER=1


# ---------------------------------------------------------------------------
# POLESTAR — vehicle status widget
# ---------------------------------------------------------------------------
# Required only if you use the `polestar` widget type.
# Use the same credentials you log in with on the Polestar app / my.polestar.com
POLESTAR_USERNAME=your@email.com
POLESTAR_PASSWORD=yourpassword


# ---------------------------------------------------------------------------
# GOOGLE CALENDAR — family/shared calendar widget
# ---------------------------------------------------------------------------
# Required only if you use the `calendar` widget type.
#
# Step-by-step setup:
#
# 1. Go to https://console.cloud.google.com and create a new project
#    (or use an existing one).
#
# 2. Enable the Google Calendar API:
#    APIs & Services → Enable APIs → search "Google Calendar API" → Enable
#
# 3. Create a Service Account:
#    APIs & Services → Credentials → Create Credentials → Service Account
#    Give it any name (e.g. "wall-cast"). No special roles needed.
#    Click "Done".
#
# 4. Download the JSON key:
#    Click the service account → Keys tab → Add Key → Create new key → JSON
#    Save the downloaded file as  config/google-sa.json  in this repo root.
#    (config/*.json is gitignored — this file will never be committed.)
#
# 5. Share your calendar with the service account:
#    Open Google Calendar → Settings → your calendar → Share with specific people
#    Add the service account email (ends in @...iam.gserviceaccount.com)
#    Permission: "See all event details" (read-only is enough)
#
# 6. Find your Calendar ID:
#    Google Calendar → Settings → your calendar → Integrate calendar
#    Copy the "Calendar ID" (looks like xxxxx@group.calendar.google.com
#    or yourname@gmail.com for a primary calendar)
#
GOOGLE_CALENDAR_ID=xxxxx@group.calendar.google.com
GOOGLE_SA_KEY_FILE=/config/google-sa.json


# ---------------------------------------------------------------------------
# TRAFFIC — travel time + highway traffic jams widget
# ---------------------------------------------------------------------------
# Required only if you use the `traffic` widget type.
#
# Free API key from https://developer.tomtom.com (no credit card required).
# Used for live traffic-aware travel time and address geocoding.
# Traffic jam list uses the ANWB public API and requires no key.
TOMTOM_API_KEY=your_tomtom_api_key
#
# Origin and destination for the travel time card.
# Full street address including postcode and country suffix (NL).
# These are geocoded to exact coordinates on first request via TomTom.
TRAFFIC_HOME_ADDRESS=Your Street 1, 1234AB Your City, NL
TRAFFIC_WORK_ADDRESS=Work Street 1, 5678CD Work City, NL
